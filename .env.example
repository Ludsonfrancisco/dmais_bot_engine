# =============================================================================
# dmais_bot_engine — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha os valores reais:
#   cp .env.example .env
#
# ATENÇÃO: O arquivo .env contém credenciais sensíveis e NÃO deve ser commitado.
# =============================================================================

# -----------------------------------------------------------------------------
# API Django (sistema principal de logística reversa)
# -----------------------------------------------------------------------------

# URL base da API Django — com protocolo e sem barra final
# Exemplo: https://api.dmais.com.br
DJANGO_API_BASE_URL=http://localhost:8001

# Token de autenticação para a API Django
# Enviado como header: Authorization: Token <key>
DJANGO_API_TOKEN=seu_token_aqui

# -----------------------------------------------------------------------------
# EvolutionAPI (gateway WhatsApp via Baileys)
# -----------------------------------------------------------------------------

# URL interna do container EvolutionAPI (dentro da rede Docker)
# Não altere se estiver usando o docker-compose padrão
EVOLUTION_API_URL=http://evolution-api:8080

# API Key global da EvolutionAPI (header: apikey)
# Definida na configuração inicial da EvolutionAPI
EVOLUTION_API_KEY= dmais-evo-prod-7f3a9b2c4d8e1f6g5h9i0j2k4l6m8n0p

# Nome da instância/sessão WhatsApp na EvolutionAPI
# Usado para identificar qual número está conectado
EVOLUTION_INSTANCE_NAME=dmais

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------

# URL de conexão com o Redis
# Não altere se estiver usando o docker-compose padrão
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Worker (configuração operacional)
# -----------------------------------------------------------------------------

# Intervalo em segundos entre cada ciclo de polling ao Django
# Valores muito baixos podem sobrecarregar a API
POLLING_INTERVAL_SECONDS=60

# Limite máximo de mensagens enviadas por minuto (token bucket)
# Valor recomendado: 4 — respeita as restrições do WhatsApp para evitar
# banimento em contas não-business. Valores maiores correm risco de bloqueio.
MAX_MESSAGES_PER_MINUTE=4

# Nível de log: DEBUG | INFO | WARNING | ERROR
# Use DEBUG apenas em desenvolvimento (inclui payloads brutos)
LOG_LEVEL=INFO

# Porta HTTP exposta pelo FastAPI do worker (webhooks + health)
WORKER_HTTP_PORT=8000
